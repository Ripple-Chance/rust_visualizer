digraph test_function_rs {
  // Graph attributes
  label="test_function.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "result_2" [label="result", shape=box, fillcolor="#4CAF50", style="filled"];
    "data_2" [label="data", shape=box, fillcolor="#4CAF50", style="filled"];
    "output_2" [label="output", shape=box, fillcolor="#4CAF50", style="filled"];
  }
  subgraph cluster_scope_1 {
    label="Scope 1";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "a_1" [label="a", shape=box, fillcolor="#4CAF50", style="filled"];
    "b_1" [label="b", shape=box, fillcolor="#4CAF50", style="filled", fontcolor="#D32F2F"];
  }

  // Variable relationships

}
