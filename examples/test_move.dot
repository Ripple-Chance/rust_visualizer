digraph test_move_rs {
  // Graph attributes
  label="test_move.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "s1_2" [label="s1", shape=box, fillcolor="#4CAF50", style="filled"];
    "s2_2" [label="s2", shape=box, fillcolor="#4CAF50", style="filled"];
    "v1_2" [label="v1", shape=box, fillcolor="#4CAF50", style="filled"];
    "v2_2" [label="v2", shape=box, fillcolor="#4CAF50", style="filled"];
    "x_2" [label="x", shape=box, fillcolor="#4CAF50", style="filled"];
    "y_2" [label="y", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
