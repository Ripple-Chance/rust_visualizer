digraph test_unused_rs {
  // Graph attributes
  label="test_unused.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "x_2" [label="x", shape=box, fillcolor="#4CAF50", style="filled"];
    "y_2" [label="y", shape=box, fillcolor="#4CAF50", style="filled"];
    "z_2" [label="z", shape=box, fillcolor="#4CAF50", style="filled"];
    "unused_2" [label="unused", shape=box, style="filled", fillcolor="#EEEEEE", fontcolor="#9E9E9E"];
  }

  // Variable relationships

}
