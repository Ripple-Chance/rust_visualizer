digraph test_struct_pattern_rs {
  // Graph attributes
  label="test_struct_pattern.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "numbers_2" [label="numbers", shape=box, fillcolor="#4CAF50", style="filled"];
    "count_2" [label="count", shape=box, fillcolor="#4CAF50", style="filled"];
    "average_2" [label="average", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
