digraph v1_test_lifetime_scope_rs {
  // Graph attributes
  label="v1_test_lifetime_scope.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_3 {
    label="Scope 3";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "inner_3" [label="inner", shape=box, fillcolor="#2196F3", style="filled"];
    "ref_inner_3" [label="ref_inner", shape=box, fillcolor="#4CAF50", style="filled"];
  }
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "outer_2" [label="outer", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
