digraph test_borrow_rs {
  // Graph attributes
  label="test_borrow.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "s1_2" [label="s1", shape=box, fillcolor="#2196F3", style="filled"];
    "r1_2" [label="r1", shape=box, fillcolor="#4CAF50", style="filled"];
    "r2_2" [label="r2", shape=box, fillcolor="#4CAF50", style="filled"];
    "s2_2" [label="s2", shape=box, fillcolor="#F44336", style="filled", fontcolor="#D32F2F"];
    "mr1_2" [label="mr1", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
