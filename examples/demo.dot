digraph demo_rs {
  // Graph attributes
  label="demo.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_1 {
    label="Scope 1";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "a_1" [label="a", shape=box, fillcolor="#4CAF50", style="filled"];
    "b_1" [label="b", shape=box, fillcolor="#4CAF50", style="filled", fontcolor="#D32F2F"];
  }
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "x_2" [label="x", shape=box, fillcolor="#4CAF50", style="filled"];
    "y_2" [label="y", shape=box, fillcolor="#4CAF50", style="filled", fontcolor="#D32F2F"];
    "result_2" [label="result", shape=box, fillcolor="#2196F3", style="filled"];
  }
  subgraph cluster_scope_3 {
    label="Scope 3";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "z_3" [label="z", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
