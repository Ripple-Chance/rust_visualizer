digraph test_mutable_rs {
  // Graph attributes
  label="test_mutable.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "name_2" [label="name", shape=box, fillcolor="#4CAF50", style="filled"];
    "age_2" [label="age", shape=box, fillcolor="#4CAF50", style="filled"];
    "is_student_2" [label="is_student", shape=box, fillcolor="#4CAF50", style="filled"];
    "score_2" [label="score", shape=box, fillcolor="#4CAF50", style="filled", fontcolor="#D32F2F"];
    "info_2" [label="info", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
