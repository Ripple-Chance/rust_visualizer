digraph test_nested_scope_rs {
  // Graph attributes
  label="test_nested_scope.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs with nodes
  subgraph cluster_scope_4 {
    label="Scope 4";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "c_4" [label="c", shape=box, fillcolor="#4CAF50", style="filled"];
  }
  subgraph cluster_scope_2 {
    label="Scope 2";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "a_2" [label="a", shape=box, fillcolor="#4CAF50", style="filled"];
  }
  subgraph cluster_scope_3 {
    label="Scope 3";
    style="filled"; fillcolor="#E3F2FD"; color="#1976D2";
    "b_3" [label="b", shape=box, fillcolor="#4CAF50", style="filled"];
  }

  // Variable relationships

}
