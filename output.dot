digraph Ownership_Graph___examples_test_ownership_rs {
  // Graph attributes
  label="Ownership Graph - examples/test_ownership.rs";
  labelloc=t;
  fontsize=16;
  fontname="Arial";
  rankdir=TB;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.8;

  // Scope subgraphs
  subgraph cluster_scope_2 {
    label="Scope 2";
    style=filled,fillcolor=#E3F2FD,color=#1976D2;
    "s1_2";
    "s2_2";
    "s3_2";
    "r1_2";
    "r2_2";
    "x_2";
    "rx_2";
  }

  // Variable nodes
  "s1_2" [label="s1", shape=box, fillcolor="#4CAF50", style=filled];
  "s2_2" [label="s2", shape=box, fillcolor="#4CAF50", style=filled];
  "s3_2" [label="s3", shape=box, fillcolor="#4CAF50", style=filled];
  "r1_2" [label="r1", shape=box, fillcolor="#4CAF50", style=filled];
  "r2_2" [label="r2", shape=box, fillcolor="#4CAF50", style=filled];
  "x_2" [label="x", shape=box, fillcolor="#4CAF50", style=filled, fontcolor=#D32F2F];
  "rx_2" [label="rx", shape=box, fillcolor="#4CAF50", style=filled];

  // Variable relationships

}
